# Base de datos
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Sesión
SESSION_SECRET=super-secret-key-change-me-in-production

# Entorno - Cambiar a production en Railway
NODE_ENV=production

# Puerto - Railway lo asigna automáticamente, no configurar manualmente
# PORT=

# URL del frontend en producción, separadas por coma si hay más de una
ALLOWED_ORIGINS=https://tu-app.vercel.app

# Almacenamiento de archivos (local | r2)
STORAGE_PROVIDER=r2

# MercadoPago
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxx-xxxxxxxxx
APP_URL=http://localhost:5173

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Resend
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev

# Cloudflare R2 - Credenciales de acceso
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
# Endpoint S3-compatible de R2 (incluir https://)
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
# Nombre del bucket en R2
R2_BUCKET_NAME=app-contratos
# URL pública del bucket (dominio custom o r2.dev)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# Ignorar validación de credenciales en local (servicios de email, R2, etc.)
SKIP_CREDENTIALS_VALIDATION=true
