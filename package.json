{
  "name": "gestion-contratos",
  "version": "1.0.0",
  "description": "Aplicación web para gestión de contratos de servicios",
  "private": true,
  "scripts": {
    "start": "node server/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/server.js",
    "client": "npm run dev --prefix client",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1028.0",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "mercadopago": "^2.12.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.13.1",
    "twilio": "^5.12.2",
    "uuid": "^11.0.5",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
